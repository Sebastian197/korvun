# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Local (non-committed) config overrides — may contain secrets
*.local.json
configs/*.local.json

# Editor/IDE
.idea/
# .vscode/

# Project artefacts kept out of the repo
KORVUN-Documento-Maestro.pdf
# Compiled CLI binary produced by `go build` at the module root.
/korvun

# OS cruft
.DS_Store

# Local SQLite databases (conversation store) and their WAL/SHM sidecars
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# Security/CI artefacts generated locally
results.sarif
*.spdx.json

# Release/distribution output (GoReleaser, future packaging)
/dist/

# Frontend tooling (future no-code builder)
node_modules/
frontend/dist/
.gstack/

# GoReleaser build output (ADR-0025, Stage 15)
dist/

# Builder frontend (ADR-0029, Stage 14 Phase 2b). The real Vite build is
# regenerated fresh (CI never trusts a committed one, §6), but the committed
# placeholder must survive the global dist/ ignore above so //go:embed dist matches
# on a clean clone and a bare `go build` compiles (§4). Re-include the dir, ignore
# its contents, keep only the placeholder.
!web/builder/dist/
web/builder/dist/*
!web/builder/dist/.gitkeep
!web/builder/dist/index.html

# Obsidian per-machine vault config (Claude Code IDE plugin)
.obsidian/

# graphify knowledge-graph build artifacts (regenerated on commit to master)
graphify-out/

# understand-anything knowledge-graph artifacts (local analysis, regenerated by /understand)
.ua/

# Design mockup drafts (Chano) — deliberately unversioned (SP2 rider)
design-drafts/
