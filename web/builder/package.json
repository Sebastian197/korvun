{
  "name": "korvun-builder",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Korvun visual builder UI (Stage 14 Phase 2b). Built to web/builder/dist and embedded in the Korvun binary via go:embed. Zero CDN.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
